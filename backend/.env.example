# E-DAARA Backend — Variables d'environnement

# ========================================
# SERVEUR
# ========================================
NODE_ENV=development
PORT=3000
HOST=0.0.0.0
APP_NAME=E-DAARA
APP_URL=http://localhost:3000

# ========================================
# BASE DE DONNÉES
# ========================================
DB_HOST=localhost
DB_PORT=3306
DB_NAME=edaara_db
DB_USER=root
DB_PASSWORD=
DB_POOL_SIZE=20
DB_ACQUIRE_TIMEOUT=30000
DB_CONNECTION_LIMIT=10

# ========================================
# JWT & SÉCURITÉ
# ========================================
JWT_SECRET=your_super_secret_jwt_key_change_in_production_minimum_32_chars
JWT_ACCESS_TOKEN_EXPIRATION=900              # 15 minutes en secondes
JWT_REFRESH_TOKEN_EXPIRATION=2592000         # 30 jours en secondes
JWT_REFRESH_TOKEN_MAX_AGE=2592000

# ========================================
# OAUTH 2.0 — Google
# ========================================
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/oauth/google/callback

# ========================================
# OAUTH 2.0 — Facebook
# ========================================
FACEBOOK_CLIENT_ID=your_facebook_app_id
FACEBOOK_CLIENT_SECRET=your_facebook_app_secret
FACEBOOK_CALLBACK_URL=http://localhost:3000/api/auth/oauth/facebook/callback

# ========================================
# EMAIL (SMTP)
# ========================================
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=your_email@gmail.com
MAIL_PASSWORD=your_app_password
MAIL_FROM_NAME=E-DAARA
MAIL_FROM_EMAIL=noreply@edaara.sn

# ========================================
# STOCKAGE FICHIERS (MinIO)
# ========================================
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_NAME=edaara-storage
MINIO_REGION=us-east-1

# ========================================
# LOGGING & MONITORING
# ========================================
LOG_LEVEL=info
LOG_FILE_PATH=./logs/app.log

# ========================================
# CORS
# ========================================
CORS_ORIGIN=http://localhost:4200,http://localhost:3000
CORS_CREDENTIALS=true

# ========================================
# RATE LIMITING
# ========================================
RATE_LIMIT_WINDOW_MS=900000      # 15 minutes
RATE_LIMIT_MAX_REQUESTS=100

# ========================================
# CONFORMITÉ & SOUVERAINETÉ
# ========================================
COUNTRY=Senegal
GDPR_COMPLIANT=true
DATA_CENTER_LOCATION=Dakar
ENCRYPTION_ENABLED=true
